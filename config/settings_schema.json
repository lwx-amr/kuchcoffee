[
  {
    "name": "theme_info",
    "theme_name": "KuchCoffee",
    "theme_version": "0.1.0",
    "theme_author": "KuchCoffee",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "caveat_n4",
        "label": "t:labels.display_font",
        "info": "t:info.display_font"
      },
      {
        "type": "font_picker",
        "id": "type_mono_font",
        "default": "space_mono_n4",
        "label": "t:labels.mono_font",
        "info": "t:info.mono_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "90rem", "label": "t:options.page_width.narrow" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "color_ink",
        "default": "#1a1410",
        "label": "t:labels.color_ink",
        "info": "t:info.color_ink"
      },
      {
        "type": "color",
        "id": "color_ink_soft",
        "default": "#3d2e20",
        "label": "t:labels.color_ink_soft"
      },
      {
        "type": "color",
        "id": "color_cream",
        "default": "#f5ede0",
        "label": "t:labels.color_cream",
        "info": "t:info.color_cream"
      },
      {
        "type": "color",
        "id": "color_gold",
        "default": "#c47a2b",
        "label": "t:labels.color_gold",
        "info": "t:info.color_gold"
      },
      {
        "type": "color",
        "id": "color_mid",
        "default": "#8a7060",
        "label": "t:labels.color_mid"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 2
      }
    ]
  },
  {
    "name": "t:general.brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_tagline",
        "default": "Istanbul × Copenhagen",
        "label": "t:labels.brand_tagline"
      }
    ]
  }
]
