{% liquid
  assign shop_menu = section.settings.shop_menu
  assign cart_count = cart.item_count
  assign color_scheme = section.settings.color_scheme | default: 'light'
  assign about_url = section.settings.about_url

  if about_url == blank
    assign about_url = pages['about'].url | default: '/pages/about'
  endif

  if request.page_type == 'index'
    assign color_scheme = 'dark'
  endif

  assign has_shop_menu = false
  if shop_menu != blank and shop_menu.links.size > 0
    assign has_shop_menu = true
  endif

  assign is_search_page = false
  if request.page_type == 'search'
    assign is_search_page = true
  endif
%}

<kc-header class="kc-header" data-scheme="{{ color_scheme }}">
  <div class="kc-header__bar">
    <a href="{{ routes.root_url }}" class="kc-header__logo" aria-label="{{ shop.name }}">
      {% render 'kc-logo', class: 'kc-header__logo-mark', label: shop.name %}
    </a>

    <nav class="kc-header__nav" aria-label="{{ 'general.primary_nav' | t }}">
      <div class="kc-header__dropdown" data-dropdown>
        <button type="button" class="kc-header__navlink" aria-haspopup="true" aria-expanded="false" data-dropdown-toggle>
          {{ 'general.shop' | t }}
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
            <path d="M1 3l3 3 3-3"/>
          </svg>
        </button>
        <div class="kc-header__menu" data-dropdown-panel role="menu">
          {% if has_shop_menu %}
            {% for link in shop_menu.links %}
              {% if link.title contains '──' or link.title contains '----' %}
                <div class="kc-header__menu-divider" role="separator"></div>
              {% else %}
                <a href="{{ link.url }}" class="kc-header__menu-item" role="menuitem">{{ link.title }}</a>
              {% endif %}
            {% endfor %}
          {% else %}
            <a href="{{ routes.collections_url }}/espresso-beans" class="kc-header__menu-item" role="menuitem">{{ 'categories_page.espresso_title' | t }}</a>
            <a href="{{ routes.collections_url }}/single-origin" class="kc-header__menu-item" role="menuitem">{{ 'categories_page.single_origin_title' | t }}</a>
            <a href="{{ routes.collections_url }}/turkish" class="kc-header__menu-item" role="menuitem">{{ 'categories_page.turkish_title' | t }}</a>
            <a href="{{ routes.collections_url }}/equipment" class="kc-header__menu-item" role="menuitem">{{ 'categories_page.equipment_title' | t }}</a>
            <a href="{{ routes.collections_url }}/package" class="kc-header__menu-item" role="menuitem">{{ 'categories_page.bundles_title' | t }}</a>
          {% endif %}
        </div>
      </div>

      {% if about_url != blank %}
        <a href="{{ about_url }}" class="kc-header__navlink">{{ 'general.about' | t }}</a>
      {% endif %}
    </nav>

    <div class="kc-header__icons">
      <a href="{{ routes.search_url }}" aria-label="{{ 'general.search' | t }}" class="kc-header__icon{% if is_search_page %} is-active{% endif %}">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
          <circle cx="6" cy="6" r="4"/><path d="M9 9l4 4"/>
        </svg>
      </a>
      <a href="/pages/favourites" aria-label="{{ 'general.favourites' | t }}" class="kc-header__icon">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
          <path d="M7 12C7 12 1.5 8.5 1.5 5a3 3 0 015.5 0 3 3 0 015.5 0C12.5 8.5 7 12 7 12z"/>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="{{ 'general.cart' | t }}" class="kc-header__icon kc-header__icon--cart">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
          <path d="M1.5 1.5h3l2 7h5l1.5-5H5.5"/><circle cx="6" cy="12" r="1" fill="currentColor"/><circle cx="11" cy="12" r="1" fill="currentColor"/>
        </svg>
        {% if cart_count > 0 %}
          <span class="kc-header__badge" aria-label="{{ cart_count }} {{ 'general.items' | t }}">{{ cart_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</kc-header>

{% stylesheet %}
  .kc-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-line);
  }
  .kc-header[data-scheme="dark"] {
    background: var(--color-ink);
    border-bottom-color: transparent;
    color: var(--color-cream);
  }
  .kc-header__bar {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    height: 56px;
    padding: 0 20px;
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
  }
  .kc-header__logo {
    display: inline-flex;
    align-items: center;
  }
  .kc-header__logo-mark {
    gap: 0.7rem;
  }
  .kc-header__logo-mark .kc-logo__kuch {
    font-size: 1.8rem;
  }
  .kc-header__logo-mark .kc-logo__coffee {
    font-size: 0.42rem;
    margin-top: 0.26rem;
  }
  .kc-header__logo-mark .kc-logo__divider {
    height: 2.7rem;
  }
  .kc-header__logo-mark .kc-logo__icon {
    width: 2.35rem;
  }

  .kc-header__nav {
    display: flex;
    gap: 22px;
    justify-content: center;
    align-items: center;
    font-size: 15px;
  }
  .kc-header__navlink {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    opacity: 0.75;
    font-size: 15px;
    transition: opacity 120ms;
  }
  .kc-header__navlink:hover { opacity: 1; }

  .kc-header__dropdown { position: relative; }
  .kc-header__dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 12px;
  }
  .kc-header__menu {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    min-width: 180px;
    background: var(--color-cream);
    border: 1.5px solid var(--color-line);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    padding: 4px 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms, transform 120ms;
  }
  .kc-header[data-scheme="dark"] .kc-header__menu {
    background: #2a2018;
    border-color: var(--color-cream-faint);
  }
  .kc-header__dropdown[data-open="true"] .kc-header__menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .kc-header__menu-item {
    display: block;
    padding: 9px 16px;
    font-size: 15px;
    border-bottom: 1px solid rgba(26, 20, 16, 0.08);
  }
  .kc-header__menu-item:last-child { border-bottom: 0; }
  .kc-header__menu-item:hover { background: var(--color-line-soft); }
  .kc-header[data-scheme="dark"] .kc-header__menu-item {
    border-bottom-color: rgba(244, 232, 216, 0.08);
  }
  .kc-header__menu-divider {
    height: 1px;
    background: var(--color-line);
    margin: 2px 0;
  }
  .kc-header[data-scheme="dark"] .kc-header__menu-divider { background: var(--color-cream-faint); }

  .kc-header__icons {
    display: flex;
    gap: 14px;
    justify-content: flex-end;
    align-items: center;
  }
  .kc-header__icon {
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--style-border-radius-inputs);
    position: relative;
    transition: background 120ms, color 120ms;
  }
  .kc-header__icon.is-active {
    background: var(--color-ink);
    color: var(--color-cream);
    border-color: var(--color-ink);
  }
  .kc-header__icon:hover { background: var(--color-ink); color: var(--color-cream); }
  .kc-header[data-scheme="dark"] .kc-header__icon { border-color: var(--color-cream-faint); }
  .kc-header[data-scheme="dark"] .kc-header__icon.is-active {
    background: var(--color-cream);
    color: var(--color-ink);
    border-color: var(--color-cream);
  }
  .kc-header[data-scheme="dark"] .kc-header__icon:hover { background: var(--color-cream); color: var(--color-ink); }

  .kc-header__badge {
    position: absolute;
    top: -5px;
    right: -5px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--color-gold);
    color: var(--color-cream);
    border-radius: 8px;
    font-family: var(--font-mono--family);
    font-size: 9px;
    display: grid;
    place-items: center;
  }

  @media (max-width: 749px) {
    .kc-header__bar {
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      height: 52px;
      padding: 0 14px;
    }
    .kc-header__logo {
      min-width: 0;
    }
    .kc-header__logo-mark {
      gap: 0.5rem;
    }
    .kc-header__logo-mark .kc-logo__kuch {
      font-size: 1.35rem;
    }
    .kc-header__logo-mark .kc-logo__coffee {
      font-size: 0.36rem;
      margin-top: 0.18rem;
      letter-spacing: 0.34em;
    }
    .kc-header__logo-mark .kc-logo__divider {
      height: 2rem;
    }
    .kc-header__logo-mark .kc-logo__icon {
      width: 1.7rem;
    }
    .kc-header__nav {
      gap: 12px;
      justify-content: flex-start;
      font-size: 13px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .kc-header__nav::-webkit-scrollbar {
      display: none;
    }
    .kc-header__navlink,
    .kc-header__menu-item {
      font-size: 13px;
    }
    .kc-header__icons {
      gap: 8px;
    }
    .kc-header__icon {
      width: 26px;
      height: 26px;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const dd = document.querySelector('kc-header [data-dropdown]');
    if (!dd) return;
    const toggle = dd.querySelector('[data-dropdown-toggle]');
    let open = false;
    const set = (v) => {
      open = v;
      dd.dataset.open = v ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', v ? 'true' : 'false');
    };
    dd.addEventListener('mouseenter', () => set(true));
    dd.addEventListener('mouseleave', () => set(false));
    toggle.addEventListener('click', (e) => { e.preventDefault(); set(!open); });
    document.addEventListener('click', (e) => { if (!dd.contains(e.target)) set(false); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) set(false); });
  })();
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "options": [
        { "value": "light", "label": "t:options.scheme.light" },
        { "value": "dark", "label": "t:options.scheme.dark" }
      ],
      "default": "light"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "t:labels.shop_menu",
      "info": "t:info.shop_menu"
    },
    {
      "type": "url",
      "id": "about_url",
      "label": "t:labels.about_url"
    }
  ]
}
{% endschema %}
