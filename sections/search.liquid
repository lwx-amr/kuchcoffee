{% liquid
  assign continue_url = routes.all_products_collection_url
  assign terms = search.terms | default: ''
%}

<section class="kc-search">
  <div class="kc-search__hero kc-home__pattern">
    <p class="kc-tag kc-tag--gold">{{ 'search.eyebrow' | t }}</p>
    <h1>{{ 'search.title' | t }}</h1>
    <div class="kc-collection__breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'collection_page.breadcrumb_home' | t }}</a>
      <span>/</span>
      <span>{{ 'search.title' | t }}</span>
    </div>
  </div>

  <div class="kc-search__body">
    <form action="{{ routes.search_url }}" method="get" role="search" class="kc-search__form">
      <input type="hidden" name="type" value="product">
      <label class="kc-sr" for="search-query">{{ 'search.title' | t }}</label>
      <input
        id="search-query"
        class="kc-search__input"
        type="search"
        name="q"
        value="{{ terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        autocomplete="off"
      >
      <button type="submit" class="kc-btn kc-btn--gold kc-search__submit">{{ 'search.submit' | t }}</button>
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <div class="kc-search__empty">
          <h2>{{ 'search.empty_title' | t }}</h2>
          <p>{{ 'search.no_results_html' | t: terms: terms }}</p>
          <a href="{{ continue_url }}" class="kc-btn">{{ 'search.continue' | t }}</a>
        </div>
      {% else %}
        <div class="kc-search__meta">
          <span>{{ 'search.results_for_html' | t: terms: terms, count: search.results_count }}</span>
        </div>

        {% paginate search.results by 20 %}
          <div class="kc-search__grid">
            {% for result in search.results %}
              {% if result.object_type == 'product' %}
                <article class="kc-search__card">
                  <a href="{{ result.url }}" class="kc-search__media">
                    {% if result.featured_image != blank %}
                      {{ result.featured_image | image_url: width: 640, height: 720, crop: 'center' | image_tag: class: 'kc-search__image', loading: 'lazy', sizes: '(max-width: 749px) 44vw, 240px', widths: '180,240,360,480,640', alt: result.featured_image.alt | default: result.title }}
                    {% else %}
                      <div class="kc-ph kc-search__image">{{ 'search.product_image' | t }}</div>
                    {% endif %}
                  </a>

                  <a href="{{ result.url }}" class="kc-search__title">{{ result.title }}</a>

                  {% if result.price_varies %}
                    <div class="kc-search__price">{{ 'landing.ui.from_price' | t: price: result.price_min | money }}</div>
                  {% else %}
                    <div class="kc-search__price">{{ result.price | money }}</div>
                  {% endif %}

                  <div class="kc-search__foot">
                    <a href="{{ result.url }}" class="kc-btn kc-btn--gold kc-search__cta">{{ 'landing.ui.buy_short' | t }}</a>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>

          <div class="kc-search__pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endpaginate %}
      {% endif %}
    {% else %}
      <div class="kc-search__empty">
        <h2>{{ 'search.prompt_title' | t }}</h2>
        <p>{{ 'search.prompt_body' | t }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .kc-search {
    background: #fff;
    min-height: 100%;
  }
  .kc-search__hero {
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 18px 20px;
    overflow: hidden;
  }
  .kc-search__hero > * {
    position: relative;
    z-index: 1;
  }
  .kc-search__hero h1 {
    margin: 0;
    margin-top: 4px;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .kc-search__body {
    padding: 16px 20px 28px;
  }
  .kc-search__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
    align-items: center;
  }
  .kc-search__input {
    width: 100%;
    min-height: 44px;
    padding: 0 14px;
    border: 1px solid var(--color-line);
    border-radius: var(--style-border-radius-inputs);
    background: #fff;
    font: inherit;
    color: var(--color-ink);
  }
  .kc-search__submit {
    min-height: 44px;
  }
  .kc-search__meta {
    margin-top: 16px;
    font-family: var(--font-mono--family);
    font-size: 10px;
    color: var(--color-mid);
    letter-spacing: 0.04em;
  }
  .kc-search__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }
  .kc-search__card {
    display: grid;
    gap: 8px;
    border: 1px solid var(--color-line);
    padding: 8px;
    background: #fff;
  }
  .kc-search__media {
    display: block;
  }
  .kc-search__image {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 3.4;
    object-fit: cover;
  }
  .kc-search__title {
    line-height: 1.25;
  }
  .kc-search__price {
    font-family: var(--font-mono--family);
    font-size: 12px;
    color: var(--color-gold);
  }
  .kc-search__foot {
    display: flex;
    justify-content: flex-start;
  }
  .kc-search__cta {
    min-width: 84px;
  }
  .kc-search__empty {
    display: grid;
    gap: 10px;
    justify-items: start;
    margin-top: 24px;
    padding: 24px;
    background: var(--color-cream);
    border: 1px solid var(--color-line);
  }
  .kc-search__empty h2 {
    margin: 0;
    font-size: 22px;
    line-height: 1;
  }
  .kc-search__empty p {
    margin: 0;
    color: var(--color-mid);
    max-width: 42ch;
  }
  .kc-search__pagination {
    margin-top: 20px;
  }
  .kc-search__pagination .pagination {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .kc-search__pagination .page,
  .kc-search__pagination .prev,
  .kc-search__pagination .next {
    display: inline-flex;
    min-width: 34px;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    border: 1px solid var(--color-line);
    border-radius: var(--style-border-radius-inputs);
  }
  .kc-search__pagination .current {
    background: var(--color-ink);
    color: var(--color-cream);
    border-color: var(--color-ink);
  }
  @media (min-width: 750px) {
    .kc-search__hero {
      padding: 24px 40px;
    }
    .kc-search__hero h1 {
      font-size: 40px;
    }
    .kc-search__body {
      padding: 24px 40px 40px;
    }
    .kc-search__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
