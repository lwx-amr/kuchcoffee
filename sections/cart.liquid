{% liquid
  assign continue_url = section.settings.continue_url
  if continue_url == blank
    assign continue_url = routes.all_products_collection_url
  endif

  assign cart_savings = 0
  if cart.original_total_price > cart.total_price
    assign cart_savings = cart.original_total_price | minus: cart.total_price
  endif

  assign summary_subtotal = cart.original_total_price
  if summary_subtotal == 0
    assign summary_subtotal = cart.total_price
  endif
%}

<section class="kc-cart" data-section-id="{{ section.id }}">
  <div class="kc-cart__hero kc-home__pattern">
    <p class="kc-tag kc-tag--gold">{{ 'cart.eyebrow' | t }}</p>
    <h1 class="kc-cart__title">{{ 'cart.title' | t }}</h1>
    <div class="kc-collection__breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'collection_page.breadcrumb_home' | t }}</a>
      <span>/</span>
      <span>{{ 'cart.title' | t }}</span>
    </div>
  </div>

  <div class="kc-collection__meta kc-cart__meta">
    <span class="kc-cart__count">{{ 'cart.items_count' | t: count: cart.item_count }}</span>
    <a class="kc-cart__continue kc-cart__continue--meta" href="{{ continue_url }}">{{ 'cart.continue' | t }}</a>
  </div>

  <div class="kc-cart__shell">

    {% if cart.item_count == 0 %}
      <div class="kc-cart__empty">
        <div class="kc-ph kc-cart__empty-visual">{{ 'cart.empty_visual' | t }}</div>
        <div class="kc-cart__empty-copy">
          <h2>{{ 'cart.empty_title' | t }}</h2>
          <p>{{ 'cart.empty_body' | t }}</p>
          <a class="kc-btn kc-btn--gold kc-cart__empty-cta" href="{{ continue_url }}">{{ 'cart.empty_cta' | t }}</a>
        </div>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" class="kc-cart__form" novalidate>
        <div class="kc-cart__items">
          {% for item in cart.items %}
            <article class="kc-cart__item">
              <a class="kc-cart__item-media" href="{{ item.url }}">
                {% if item.image != blank %}
                  {{ item.image | image_url: width: 320, height: 320, crop: 'center' | image_tag: class: 'kc-cart__item-image', loading: 'lazy', widths: '140,220,320', sizes: '70px', alt: item.image.alt | default: item.product.title }}
                {% else %}
                  <div class="kc-ph kc-cart__item-image">{{ 'cart.empty_visual' | t }}</div>
                {% endif %}
              </a>

              <div class="kc-cart__item-body">
                <div class="kc-cart__item-main">
                  <div class="kc-cart__item-copy">
                    <a class="kc-cart__item-title" href="{{ item.url }}">{{ item.product.title }}</a>

                    {% capture item_details %}
                      {% unless item.product.has_only_default_variant %}
                        {% for option in item.options_with_values %}
                          {{ option.value }}{% unless forloop.last %} · {% endunless %}
                        {% endfor %}
                      {% endunless %}
                    {% endcapture %}
                    {% assign item_details = item_details | strip %}

                    {% if item_details != blank %}
                      {% assign item_category = item.product.type | default: item.vendor %}
                      {% if item_category == blank %}
                        {% assign item_category = 'cart.item_details_fallback' | t %}
                      {% endif %}
                      <p class="kc-cart__item-sub">{{ item_category }} · {{ item_details }}</p>
                    {% elsif item.product.type != blank or item.vendor != blank %}
                      <p class="kc-cart__item-sub">{{ item.product.type | default: item.vendor }}</p>
                    {% endif %}

                    {% if item.selling_plan_allocation != blank %}
                      <p class="kc-cart__item-meta-line">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                    {% endif %}

                    {% if item.properties != blank %}
                      <ul class="kc-cart__meta-list">
                        {% for property in item.properties %}
                          {% assign property_key = property.first %}
                          {% assign property_value = property.last %}
                          {% assign property_prefix = property_key | slice: 0, 1 %}
                          {% if property_value != blank and property_prefix != '_' %}
                            <li>{{ property_key }}: {{ property_value }}</li>
                          {% endif %}
                        {% endfor %}
                      </ul>
                    {% endif %}

                    {% if item.line_level_discount_allocations.size > 0 %}
                      <ul class="kc-cart__discounts">
                        {% for discount_allocation in item.line_level_discount_allocations %}
                          <li>{{ discount_allocation.discount_application.title }} · -{{ discount_allocation.amount | money }}</li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>

                  <strong class="kc-cart__item-price">
                    {% if item.original_line_price != item.final_line_price %}
                      <span class="kc-cart__item-price-compare">{{ item.original_line_price | money }}</span>
                    {% endif %}
                    <span>{{ item.final_line_price | money }}</span>
                  </strong>
                </div>

                <div class="kc-cart__item-actions">
                  <label class="kc-cart__qty" for="cart-qty-{{ item.index | default: forloop.index0 }}">
                    <span class="kc-sr">{{ 'cart.quantity' | t }}</span>
                    <button class="kc-cart__qty-btn" type="button" data-qty-change="-1" aria-label="{{ 'cart.decrease_quantity' | t }}">
                      −
                    </button>
                    <input
                      id="cart-qty-{{ item.index | default: forloop.index0 }}"
                      class="kc-cart__qty-input"
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      inputmode="numeric"
                    >
                    <button class="kc-cart__qty-btn" type="button" data-qty-change="1" aria-label="{{ 'cart.increase_quantity' | t }}">
                      +
                    </button>
                  </label>

                  <div class="kc-cart__item-links">
                    <a class="kc-cart__item-link" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
                    {% if item.product.handle != blank %}
                      <button
                        class="kc-cart__item-link kc-cart__item-link--accent"
                        type="button"
                        data-kc-fav="{{ item.product.handle }}"
                        aria-pressed="false"
                        aria-label="{{ 'favourites_page.save' | t }}">
                        {{ 'cart.save' | t }}
                      </button>
                    {% endif %}
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="kc-cart__promo">
          <p class="kc-tag">{{ 'cart.promo_title' | t }}</p>
          <div class="kc-cart__promo-row">
            <label class="kc-cart__promo-field" for="cart-promo-{{ section.id }}">
              <span class="kc-sr">{{ 'cart.promo_title' | t }}</span>
              <input id="cart-promo-{{ section.id }}" type="text" placeholder="{{ 'cart.promo_placeholder' | t }}" disabled>
            </label>
            <button class="kc-btn kc-cart__promo-button" type="button" disabled>{{ 'cart.promo_cta' | t }}</button>
          </div>
          <p class="kc-cart__promo-note">{{ 'cart.promo_helper' | t }}</p>
        </div>

        <div class="kc-cart__summary">
          <div class="kc-cart__summary-card">
            <h2>{{ 'cart.summary_title' | t }}</h2>

            <div class="kc-cart__summary-row">
              <span>{{ 'cart.subtotal' | t }}</span>
              <strong>{{ summary_subtotal | money }}</strong>
            </div>

            <div class="kc-cart__summary-row">
              <span>{{ 'cart.shipping_label' | t }}</span>
              <strong>{{ 'cart.shipping_value' | t }}</strong>
            </div>

            {% if cart.cart_level_discount_applications.size > 0 %}
              {% for discount_application in cart.cart_level_discount_applications %}
                <div class="kc-cart__summary-row kc-cart__summary-row--accent">
                  <span>{{ 'cart.promo_summary' | t: title: discount_application.title }}</span>
                  <strong>−{{ discount_application.total_allocated_amount | money }}</strong>
                </div>
              {% endfor %}
            {% elsif cart_savings > 0 %}
              <div class="kc-cart__summary-row kc-cart__summary-row--accent">
                <span>{{ 'cart.savings' | t }}</span>
                <strong>−{{ cart_savings | money }}</strong>
              </div>
            {% endif %}

            <div class="kc-cart__summary-total">
              <span>{{ 'cart.total' | t }}</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>
          </div>

          {% if section.settings.show_note %}
            <label class="kc-cart__note" for="cart-note-{{ section.id }}">
              <span>{{ 'cart.order_note' | t }}</span>
              <textarea id="cart-note-{{ section.id }}" name="note" rows="4" placeholder="{{ 'cart.order_note_placeholder' | t }}">{{ cart.note }}</textarea>
            </label>
          {% endif %}

          <div class="kc-cart__cta">
            <button class="kc-btn kc-btn--gold kc-cart__checkout" type="submit" name="checkout">{{ 'cart.checkout' | t }}</button>
            <a class="kc-cart__continue" href="{{ continue_url }}">← {{ 'cart.continue' | t }}</a>
            <p class="kc-cart__secure">{{ 'cart.secure_notice' | t }}</p>
          </div>

          <button class="kc-cart__update" type="submit" name="update">{{ 'cart.update' | t }}</button>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .kc-cart {
    padding: 0 16px 40px;
  }

  .kc-cart__hero {
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 18px 20px;
    overflow: hidden;
    max-width: 420px;
    margin: 0 auto;
  }

  .kc-cart__hero > * {
    position: relative;
    z-index: 1;
  }

  .kc-cart__meta {
    max-width: 420px;
    margin: 0 auto;
  }

  .kc-cart__shell {
    max-width: 420px;
    margin: 0 auto;
    background: #fff;
    border-left: 1px solid var(--color-line);
    border-right: 1px solid var(--color-line);
  }

  .kc-cart__title {
    margin: 0;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .kc-cart__summary-card h2,
  .kc-cart__empty-copy h2 {
    margin: 0;
    font-size: 22px;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .kc-cart__count,
  .kc-cart__item-sub,
  .kc-cart__item-meta-line,
  .kc-cart__meta-list,
  .kc-cart__discounts,
  .kc-cart__promo-note,
  .kc-cart__secure,
  .kc-cart__item-price-compare {
    margin: 0;
    font-family: var(--font-mono--family);
    font-size: 9px;
    letter-spacing: 0.04em;
    color: var(--color-mid);
  }

  .kc-cart__continue--meta {
    font-family: var(--font-primary--family);
    font-size: 13px;
    color: var(--color-gold);
  }

  .kc-cart__empty {
    display: grid;
    gap: 18px;
    padding: 20px;
  }

  .kc-cart__empty-visual {
    min-height: 220px;
  }

  .kc-cart__empty-copy {
    display: grid;
    gap: 12px;
  }

  .kc-cart__empty-copy p {
    margin: 0;
    color: var(--color-mid);
  }

  .kc-cart__empty-cta {
    width: 100%;
  }

  .kc-cart__form {
    display: grid;
  }

  .kc-cart__items {
    padding: 0 20px;
  }

  .kc-cart__item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-line);
  }

  .kc-cart__item-media {
    flex: 0 0 70px;
  }

  .kc-cart__item-image {
    display: block;
    width: 70px;
    height: 70px;
    object-fit: cover;
    background: var(--color-cream);
  }

  .kc-cart__item-body {
    display: grid;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }

  .kc-cart__item-main {
    display: flex;
    gap: 12px;
    justify-content: space-between;
    align-items: flex-start;
  }

  .kc-cart__item-copy {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .kc-cart__item-title {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.15;
  }

  .kc-cart__meta-list,
  .kc-cart__discounts {
    display: grid;
    gap: 2px;
    padding: 0;
    list-style: none;
  }

  .kc-cart__discounts {
    color: var(--color-gold);
  }

  .kc-cart__item-price {
    display: grid;
    gap: 2px;
    justify-items: end;
    flex: 0 0 auto;
    font-family: var(--font-mono--family);
    font-size: 13px;
    line-height: 1.1;
    color: var(--color-ink);
  }

  .kc-cart__item-price-compare {
    text-decoration: line-through;
  }

  .kc-cart__item-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .kc-cart__qty {
    display: grid;
    grid-template-columns: 24px 28px 24px;
    align-items: center;
    border: 1px solid var(--color-line);
    background: #fff;
  }

  .kc-cart__qty-btn,
  .kc-cart__qty-input,
  .kc-cart__promo-field input,
  .kc-cart__note textarea {
    font: inherit;
    color: inherit;
  }

  .kc-cart__qty-btn,
  .kc-cart__qty-input {
    width: 100%;
    height: 24px;
    padding: 0;
    text-align: center;
  }

  .kc-cart__qty-btn:first-of-type {
    border-right: 1px solid var(--color-line);
  }

  .kc-cart__qty-btn:last-of-type {
    border-left: 1px solid var(--color-line);
  }

  .kc-cart__qty-input {
    border: 0;
    background: transparent;
    appearance: textfield;
  }

  .kc-cart__qty-input::-webkit-outer-spin-button,
  .kc-cart__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .kc-cart__item-links {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .kc-cart__item-link {
    padding: 0;
    font-size: 11px;
    color: var(--color-mid);
  }

  .kc-cart__item-link--accent {
    color: var(--color-gold);
  }

  .kc-cart__promo,
  .kc-cart__summary-card,
  .kc-cart__cta,
  .kc-cart__note {
    padding: 12px 20px;
  }

  .kc-cart__promo,
  .kc-cart__summary-card {
    border-top: 1px solid var(--color-line);
  }

  .kc-cart__promo-row {
    display: flex;
    gap: 8px;
    margin-top: 6px;
  }

  .kc-cart__promo-field {
    flex: 1;
  }

  .kc-cart__promo-field input {
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: 0;
    background: #fff;
    padding: 8px 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .kc-cart__promo-field input::placeholder {
    color: color-mix(in srgb, var(--color-ink) 30%, transparent);
  }

  .kc-cart__promo-button[disabled],
  .kc-cart__promo-field input[disabled] {
    opacity: 1;
    cursor: not-allowed;
  }

  .kc-cart__promo-note {
    margin-top: 8px;
  }

  .kc-cart__summary-card {
    background: var(--color-cream);
    display: grid;
    gap: 8px;
  }

  .kc-cart__summary-card h2 {
    font-size: 15px;
  }

  .kc-cart__summary-row,
  .kc-cart__summary-total {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    font-size: 13px;
    color: var(--color-mid);
  }

  .kc-cart__summary-row strong,
  .kc-cart__summary-total strong {
    font-family: var(--font-mono--family);
    font-size: 11px;
    color: var(--color-ink);
  }

  .kc-cart__summary-row--accent,
  .kc-cart__summary-row--accent strong {
    color: var(--color-gold);
  }

  .kc-cart__summary-total {
    padding-top: 8px;
    margin-top: 6px;
    border-top: 1.5px solid var(--color-ink);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .kc-cart__summary-total strong {
    font-size: 16px;
    font-weight: 700;
  }

  .kc-cart__note {
    display: grid;
    gap: 8px;
  }

  .kc-cart__note span {
    font-family: var(--font-mono--family);
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-mid);
  }

  .kc-cart__note textarea {
    width: 100%;
    min-height: 96px;
    padding: 10px 12px;
    border: 1px solid var(--color-line);
    resize: vertical;
    background: #fff;
  }

  .kc-cart__cta {
    display: grid;
    gap: 8px;
    text-align: center;
  }

  .kc-cart__checkout {
    width: 100%;
    padding-top: 12px;
    padding-bottom: 12px;
    font-size: 16px;
  }

  .kc-cart__continue {
    font-size: 12px;
    color: var(--color-gold);
  }

  .kc-cart__secure {
    font-size: 8px;
  }

  .kc-cart__update {
    margin: 0 20px 16px;
    padding: 0;
    justify-self: start;
    font-family: var(--font-mono--family);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mid);
    border-bottom: 1px solid currentColor;
  }

  @media screen and (min-width: 750px) {
    .kc-cart {
      padding-top: 16px;
      padding-bottom: 56px;
    }

    .kc-cart__shell {
      box-shadow: 0 18px 48px rgba(26, 20, 16, 0.08);
    }

    .kc-cart__hero {
      padding: 24px 40px;
    }

    .kc-cart__title {
      font-size: 40px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('click', function(event) {
    var trigger = event.target.closest('[data-qty-change]');

    if (!trigger) return;

    var input = trigger.parentElement.querySelector('.kc-cart__qty-input');
    if (!input) return;

    var delta = parseInt(trigger.getAttribute('data-qty-change'), 10);
    var currentValue = parseInt(input.value, 10);

    if (isNaN(delta)) delta = 0;
    if (isNaN(currentValue)) currentValue = 0;

    currentValue = currentValue + delta;
    if (currentValue < 0) currentValue = 0;

    input.value = currentValue;
    input.dispatchEvent(new Event('change', { bubbles: true }));
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "url",
      "id": "continue_url",
      "label": "t:labels.cart_continue_url"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "t:labels.show_order_note",
      "default": true
    }
  ]
}
{% endschema %}
