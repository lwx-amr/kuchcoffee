{% liquid
  assign continue_url = section.settings.continue_url
  if continue_url == blank
    assign continue_url = routes.all_products_collection_url
  endif

  assign cart_savings = 0
  if cart.original_total_price > cart.total_price
    assign cart_savings = cart.original_total_price | minus: cart.total_price
  endif
%}

<section class="kc-cart" data-section-id="{{ section.id }}">
  <div class="kc-cart__top">
    <p class="kc-tag">{{ 'cart.eyebrow' | t }}</p>
    <div class="kc-cart__top-row">
      <h1 class="kc-cart__title">{{ 'cart.title' | t }}</h1>
      <a class="kc-cart__continue" href="{{ continue_url }}">{{ 'cart.continue' | t }}</a>
    </div>
    <p class="kc-cart__count">{{ 'cart.items_count' | t: count: cart.item_count }}</p>
  </div>

  {% if cart.item_count == 0 %}
    <div class="kc-cart__empty">
      <div class="kc-cart__empty-copy">
        <h2>{{ 'cart.empty_title' | t }}</h2>
        <p>{{ 'cart.empty_body' | t }}</p>
        <a class="kc-btn kc-btn--gold" href="{{ continue_url }}">{{ 'cart.empty_cta' | t }}</a>
      </div>
      <div class="kc-cart__empty-art">
        <div class="kc-ph kc-cart__empty-image">{{ 'cart.empty_visual' | t }}</div>
      </div>
    </div>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post" class="kc-cart__form">
      <div class="kc-cart__layout">
        <div class="kc-cart__items">
          {% for item in cart.items %}
            <article class="kc-cart__item">
              <a class="kc-cart__item-media" href="{{ item.url }}">
                {% if item.image != blank %}
                  {{ item.image | image_url: width: 520 | image_tag: class: 'kc-cart__item-image', loading: 'lazy', sizes: '(max-width: 749px) 28vw, 180px', widths: '120,180,260,360,520', alt: item.image.alt | default: item.product.title }}
                {% else %}
                  <div class="kc-ph kc-cart__item-image">{{ 'cart.empty_visual' | t }}</div>
                {% endif %}
              </a>

              <div class="kc-cart__item-copy">
                <div class="kc-cart__item-head">
                  <div>
                    {% if item.vendor != blank %}
                      <p class="kc-tag">{{ item.vendor }}</p>
                    {% endif %}
                    <a class="kc-cart__item-title" href="{{ item.url }}">{{ item.product.title }}</a>
                  </div>
                  <div class="kc-cart__item-line-total">
                    {% if item.original_line_price != item.final_line_price %}
                      <span class="kc-cart__item-line-compare">{{ item.original_line_price | money }}</span>
                    {% endif %}
                    <span>{{ item.final_line_price | money }}</span>
                  </div>
                </div>

                <div class="kc-cart__item-meta">
                  {% unless item.product.has_only_default_variant %}
                    <ul class="kc-cart__meta-list">
                      {% for option in item.options_with_values %}
                        <li>{{ option.name }}: {{ option.value }}</li>
                      {% endfor %}
                    </ul>
                  {% endunless %}

                  {% if item.selling_plan_allocation != blank %}
                    <p>{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {% endif %}

                  {% if item.properties != blank %}
                    <ul class="kc-cart__meta-list">
                      {% for property in item.properties %}
                        {% assign property_key = property.first %}
                        {% assign property_value = property.last %}
                        {% assign property_prefix = property_key | slice: 0, 1 %}
                        {% if property_value != blank and property_prefix != '_' %}
                          <li>{{ property_key }}: {{ property_value }}</li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  {% endif %}

                  {% if item.line_level_discount_allocations.size > 0 %}
                    <ul class="kc-cart__discounts">
                      {% for discount_allocation in item.line_level_discount_allocations %}
                        <li>{{ discount_allocation.discount_application.title }} · -{{ discount_allocation.amount | money }}</li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>

                <div class="kc-cart__item-foot">
                  <div class="kc-cart__unit-price">
                    <span>{{ 'cart.unit_price' | t }}</span>
                    <strong>{{ item.final_price | money }}</strong>
                  </div>

                  <label class="kc-cart__qty" for="cart-qty-{{ item.index | default: forloop.index0 }}">
                    <span class="kc-sr">{{ 'cart.quantity' | t }}</span>
                    <button class="kc-cart__qty-btn" type="button" data-qty-change="-1" aria-label="{{ 'cart.decrease_quantity' | t }}">
                      -
                    </button>
                    <input
                      id="cart-qty-{{ item.index | default: forloop.index0 }}"
                      class="kc-cart__qty-input"
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      inputmode="numeric"
                    >
                    <button class="kc-cart__qty-btn" type="button" data-qty-change="1" aria-label="{{ 'cart.increase_quantity' | t }}">
                      +
                    </button>
                  </label>

                  <a class="kc-cart__remove" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        <aside class="kc-cart__summary">
          <div class="kc-cart__summary-card">
            <h2>{{ 'cart.summary_title' | t }}</h2>

            <div class="kc-cart__summary-row">
              <span>{{ 'cart.subtotal' | t }}</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>

            {% if cart_savings > 0 %}
              <div class="kc-cart__summary-row kc-cart__summary-row--accent">
                <span>{{ 'cart.savings' | t }}</span>
                <strong>-{{ cart_savings | money }}</strong>
              </div>
            {% endif %}

            {% if cart.cart_level_discount_applications.size > 0 %}
              <ul class="kc-cart__discounts kc-cart__discounts--summary">
                {% for discount_application in cart.cart_level_discount_applications %}
                  <li>{{ discount_application.title }} · -{{ discount_application.total_allocated_amount | money }}</li>
                {% endfor %}
              </ul>
            {% endif %}

            {% if section.settings.show_note %}
              <label class="kc-cart__note" for="cart-note-{{ section.id }}">
                <span>{{ 'cart.order_note' | t }}</span>
                <textarea id="cart-note-{{ section.id }}" name="note" rows="4" placeholder="{{ 'cart.order_note_placeholder' | t }}">{{ cart.note }}</textarea>
              </label>
            {% endif %}

            <p class="kc-cart__notice">{{ 'cart.shipping_notice' | t }}</p>

            <div class="kc-cart__actions">
              <button class="kc-btn" type="submit" name="update">{{ 'cart.update' | t }}</button>
              <button class="kc-btn kc-btn--gold" type="submit" name="checkout">{{ 'cart.checkout' | t }}</button>
            </div>
          </div>
        </aside>
      </div>
    </form>
  {% endif %}
</section>

{% stylesheet %}
  .kc-cart {
    padding: 28px 20px 48px;
  }

  .kc-cart__top {
    display: grid;
    gap: 8px;
    margin-bottom: 24px;
  }

  .kc-cart__top-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: baseline;
    justify-content: space-between;
  }

  .kc-cart__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .kc-cart__continue,
  .kc-cart__count,
  .kc-cart__unit-price,
  .kc-cart__notice,
  .kc-cart__meta-list,
  .kc-cart__discounts {
    font-family: var(--font-mono--family);
    font-size: 11px;
    letter-spacing: 0.05em;
  }

  .kc-cart__continue {
    color: var(--color-gold);
  }

  .kc-cart__count,
  .kc-cart__notice,
  .kc-cart__meta-list,
  .kc-cart__discounts,
  .kc-cart__item-line-compare {
    color: var(--color-mid);
  }

  .kc-cart__empty {
    display: grid;
    gap: 18px;
    align-items: center;
    padding: 18px 0 8px;
  }

  .kc-cart__empty-copy,
  .kc-cart__summary-card {
    display: grid;
    gap: 16px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--color-line);
    border-radius: calc(var(--style-border-radius-inputs) * 1.4);
    backdrop-filter: blur(10px);
  }

  .kc-cart__empty-copy h2,
  .kc-cart__summary-card h2 {
    margin: 0;
    font-size: 24px;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .kc-cart__empty-copy p {
    margin: 0;
    max-width: 32rem;
  }

  .kc-cart__empty-image {
    min-height: 260px;
    border-radius: calc(var(--style-border-radius-inputs) * 1.6);
  }

  .kc-cart__layout {
    display: grid;
    gap: 22px;
    align-items: start;
  }

  .kc-cart__items {
    display: grid;
    gap: 14px;
  }

  .kc-cart__item {
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr);
    gap: 14px;
    padding: 14px;
    border: 1px solid var(--color-line);
    border-radius: calc(var(--style-border-radius-inputs) * 1.4);
    background: rgba(255, 255, 255, 0.8);
  }

  .kc-cart__item-media {
    display: block;
  }

  .kc-cart__item-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1.15;
    object-fit: cover;
    border-radius: calc(var(--style-border-radius-inputs) * 1.1);
    background: #fff;
  }

  .kc-cart__item-copy {
    display: grid;
    gap: 14px;
    min-width: 0;
  }

  .kc-cart__item-head,
  .kc-cart__item-foot,
  .kc-cart__summary-row,
  .kc-cart__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
  }

  .kc-cart__item-title {
    display: inline-block;
    margin-top: 4px;
    font-size: 1.1rem;
    line-height: 1.1;
  }

  .kc-cart__item-line-total {
    display: grid;
    justify-items: end;
    flex: 0 0 auto;
    text-align: right;
    font-family: var(--font-mono--family);
    font-size: 12px;
  }

  .kc-cart__item-line-compare {
    text-decoration: line-through;
  }

  .kc-cart__item-meta {
    display: grid;
    gap: 8px;
  }

  .kc-cart__meta-list,
  .kc-cart__discounts {
    display: grid;
    gap: 4px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .kc-cart__discounts {
    color: var(--color-gold);
  }

  .kc-cart__unit-price {
    display: grid;
    gap: 2px;
  }

  .kc-cart__unit-price strong {
    color: var(--color-ink);
    font-size: 14px;
  }

  .kc-cart__qty {
    display: inline-grid;
    grid-template-columns: 34px 58px 34px;
    align-items: center;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
  }

  .kc-cart__qty-btn,
  .kc-cart__qty-input,
  .kc-cart__note textarea {
    font: inherit;
    color: inherit;
  }

  .kc-cart__qty-btn {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
  }

  .kc-cart__qty-input {
    width: 100%;
    min-width: 0;
    border: 0;
    padding: 0;
    text-align: center;
    background: transparent;
    appearance: textfield;
  }

  .kc-cart__qty-input::-webkit-outer-spin-button,
  .kc-cart__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .kc-cart__remove {
    font-family: var(--font-mono--family);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-mid);
    border-bottom: 1px solid currentColor;
  }

  .kc-cart__summary {
    position: sticky;
    top: 18px;
  }

  .kc-cart__summary-card {
    gap: 14px;
  }

  .kc-cart__summary-row {
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-line);
    font-size: 14px;
  }

  .kc-cart__summary-row--accent {
    color: var(--color-gold);
  }

  .kc-cart__discounts--summary {
    padding-bottom: 4px;
  }

  .kc-cart__note {
    display: grid;
    gap: 8px;
  }

  .kc-cart__note span {
    font-family: var(--font-mono--family);
    font-size: 11px;
    letter-spacing: 0.05em;
  }

  .kc-cart__note textarea {
    width: 100%;
    resize: vertical;
    border: 1px solid var(--color-line);
    border-radius: calc(var(--style-border-radius-inputs) * 1.2);
    background: rgba(255, 255, 255, 0.7);
    padding: 12px 14px;
    min-height: 110px;
  }

  .kc-cart__notice {
    margin: 0;
  }

  .kc-cart__actions {
    flex-wrap: wrap;
  }

  .kc-cart__actions .kc-btn {
    flex: 1 1 180px;
  }

  @media screen and (min-width: 990px) {
    .kc-cart {
      padding: 36px 32px 64px;
    }

    .kc-cart__empty {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 36vw);
      gap: 24px;
    }

    .kc-cart__layout {
      grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.8fr);
      gap: 24px;
    }

    .kc-cart__item {
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 18px;
      padding: 18px;
    }
  }

  @media screen and (max-width: 749px) {
    .kc-cart__item {
      grid-template-columns: 88px minmax(0, 1fr);
    }

    .kc-cart__item-head,
    .kc-cart__item-foot {
      align-items: start;
      flex-direction: column;
    }

    .kc-cart__item-line-total {
      justify-items: start;
      text-align: left;
    }

    .kc-cart__qty {
      margin-top: 2px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('click', function(event) {
    var trigger = event.target.closest('[data-qty-change]');

    if (!trigger) return;

    var input = trigger.parentElement.querySelector('.kc-cart__qty-input');
    if (!input) return;

    var delta = parseInt(trigger.getAttribute('data-qty-change'), 10);
    var currentValue = parseInt(input.value, 10);
    var nextValue = currentValue + delta;

    if (isNaN(currentValue)) currentValue = 0;
    if (isNaN(delta)) delta = 0;

    nextValue = currentValue + delta;
    if (nextValue < 0) nextValue = 0;

    input.value = nextValue;
    input.dispatchEvent(new Event('change', { bubbles: true }));
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "url",
      "id": "continue_url",
      "label": "t:labels.cart_continue_url"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "t:labels.show_order_note",
      "default": true
    }
  ]
}
{% endschema %}
