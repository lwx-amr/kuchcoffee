{% doc %}
  KuchCoffee product card for the homepage rows.
  Layout matches the V1 Ritual wireframe: absolute tag top-right, image,
  name, footer with price + small "Buy" button.

  Accepts either a real Shopify `product` OR placeholder strings:
    sample_name, sample_tag, sample_price
  so the landing page renders correctly before real products are added.

  @param {product} [product]
  @param {string}  [sample_name]
  @param {string}  [sample_tag]
  @param {string}  [sample_price]

  @example
  {% render 'kc-product-card', product: product %}
  {% render 'kc-product-card',
     sample_name: 'Ethiopia Yirgacheffe', sample_tag: 'New', sample_price: '$24' %}
{% enddoc %}

{% liquid
  assign has_product = false
  if product != blank and product.id != blank
    assign has_product = true
  endif

  if has_product
    assign price_variant = product.selected_or_first_available_variant
    assign size_option_position = 0
    assign size_option_value = blank

    for option in product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'size' or option_name contains 'weight'
        assign size_option_position = option.position
        assign size_option_value = option.values.first
        break
      endif
    endfor

    if size_option_position > 0 and size_option_value != blank
      assign matched_variant = blank

      for variant in product.variants
        assign variant_size_value = blank
        case size_option_position
          when 1
            assign variant_size_value = variant.option1
          when 2
            assign variant_size_value = variant.option2
          when 3
            assign variant_size_value = variant.option3
        endcase

        if variant_size_value == size_option_value
          if matched_variant == blank or variant.price < matched_variant.price
            assign matched_variant = variant
          endif
        endif
      endfor

      if matched_variant != blank
        assign price_variant = matched_variant
      endif
    endif

    assign display_price = price_variant.price
    if display_price == blank or display_price <= 0
      assign display_price = product.price_min
    endif

    assign card_name = product.title
    assign card_url = product.url
    assign card_wrapper = 'a'
    if product.metafields.custom.badge != blank
      assign card_tag = product.metafields.custom.badge
    elsif product.compare_at_price > product.price
      assign card_tag = 'landing.ui.sale' | t
    elsif product.available == false
      assign card_tag = 'landing.ui.sold_out' | t
    else
      assign card_tag = ''
    endif
    assign card_price_money = display_price | money
  else
    assign card_name = sample_name | default: 'Product'
    assign card_tag = sample_tag | default: ''
    assign card_price = sample_price | default: ''
    assign card_url = blank
    assign card_wrapper = 'div'
  endif
%}

<article class="kc-pcard">
  <{{ card_wrapper }}
    class="kc-pcard__media"
    {% if card_url != blank %}
      href="{{ card_url }}"
      aria-label="{{ card_name }}"
    {% endif %}
  >
    {% if has_product and product.featured_image != blank %}
      {{ product.featured_image
        | image_url: width: 480
        | image_tag:
            class: 'kc-pcard__image',
            loading: 'lazy',
            sizes: '(max-width: 749px) 30vw, 220px',
            widths: '160,240,360,480',
            alt: product.featured_image.alt | default: product.title
      }}
    {% else %}
      <div class="kc-ph kc-pcard__image">{{ card_name }}</div>
    {% endif %}

    {% if card_tag != blank %}
      <span class="kc-pcard__tag">{{ card_tag }}</span>
    {% endif %}
  </{{ card_wrapper }}>

  {% if has_product %}
    <button type="button"
            class="kc-fav kc-fav--card"
            data-kc-fav="{{ product.handle }}"
            aria-pressed="false"
            aria-label="{{ 'favourites_page.save' | t }}">
      <svg class="kc-fav__icon kc-fav__icon--outline" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M8 13.5C8 13.5 1.5 9.5 1.5 5.5a3.2 3.2 0 016.5 0 3.2 3.2 0 016.5 0C14.5 9.5 8 13.5 8 13.5z"/>
      </svg>
      <svg class="kc-fav__icon kc-fav__icon--filled" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 13.5C8 13.5 1.5 9.5 1.5 5.5a3.2 3.2 0 016.5 0 3.2 3.2 0 016.5 0C14.5 9.5 8 13.5 8 13.5z"/>
      </svg>
    </button>
  {% endif %}

  {% if card_url != blank %}
    <a href="{{ card_url }}" class="kc-pcard__name">{{ card_name }}</a>
  {% else %}
    <div class="kc-pcard__name">{{ card_name }}</div>
  {% endif %}

  <div class="kc-pcard__foot">
    <span class="kc-pcard__price">
      {% if has_product %}
        <span class="kc-pcard__price-prefix">{{ 'landing.ui.starting_from' | t }}</span>
        <span class="kc-pcard__price-value">{{ card_price_money }}</span>
      {% else %}
        <span class="kc-pcard__price-value">{{ card_price }}</span>
      {% endif %}
    </span>
    {% if has_product %}
      <a href="{{ card_url }}" class="kc-pcard__add{% unless product.available %} kc-pcard__add--disabled{% endunless %}">{{ 'landing.ui.buy_short' | t }}</a>
    {% else %}
      <span class="kc-pcard__add kc-pcard__add--demo">{{ 'landing.ui.buy_short' | t }}</span>
    {% endif %}
  </div>
</article>
